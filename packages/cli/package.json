{
  "name": "@openlapp/cli",
  "version": "1.0.0",
  "description": "CLI for LAPP v1 (Local AI Provider Profiles). Thin wrapper over @openlapp/lapp.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "lapp": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openlapp/lapp-js.git",
    "directory": "packages/cli"
  },
  "keywords": ["lapp", "ai", "llm", "provider", "profile", "cli"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly && tsup",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@openlapp/lapp": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}