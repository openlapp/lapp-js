{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lapp.dev/schema/1.0/models.schema.json",
  "title": "LAPP v1 models.json",
  "type": "object",
  "required": ["schemaVersion", "models"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "models": {
      "type": "array",
      "items": { "$ref": "#/$defs/model" }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "nonBlank": {
      "type": "string",
      "pattern": "^(?!\\s*$)[^\\u0000-\\u001F\\u007F]+$"
    },
    "protocolId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "stringSet": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonBlank" }
    },
    "model": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonBlank" },
        "name": { "$ref": "#/$defs/nonBlank" },
        "aliases": { "$ref": "#/$defs/stringSet" },
        "enabled": { "type": "boolean" },
        "protocols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/protocolId" }
        },
        "type": { "$ref": "#/$defs/nonBlank" },
        "inputModalities": { "$ref": "#/$defs/stringSet" },
        "outputModalities": { "$ref": "#/$defs/stringSet" },
        "capabilities": { "$ref": "#/$defs/stringSet" },
        "contextWindow": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
