{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lapp.dev/schema/provider.schema.json",
  "title": "LAPP provider.json",
  "type": "object",
  "required": ["id", "baseUrl"],
  "anyOf": [
    { "required": ["protocols"] },
    { "required": ["protocol"] }
  ],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "enabled": { "type": "boolean" },
    "protocol": { "type": "string", "minLength": 1 },
    "protocols": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "type": "string", "minLength": 1 },
          {
            "type": "object",
            "required": ["id"],
            "additionalProperties": true,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "baseUrl": { "type": "string", "minLength": 1 },
              "requestHeaders": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "capabilities": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        ]
      }
    },
    "baseUrl": { "type": "string", "minLength": 1 },
    "links": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "auth": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "secret": { "type": "string" },
        "header": { "type": "string" },
        "queryParam": { "type": "string" }
      }
    },
    "requestHeaders": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
