{
  "name": "@openlapp/lapp",
  "version": "0.1.0",
  "description": "TypeScript SDK for LAPP (Local AI Provider Profiles): read, validate, write, manage, and send requests to configured providers.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openlapp/lapp-js.git",
    "directory": "packages/lapp"
  },
  "keywords": ["lapp", "ai", "llm", "provider", "profile", "sdk", "openai", "anthropic"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "copy-schema": "node ../../scripts/copy-schema.mjs",
    "prebuild": "pnpm run copy-schema",
    "build": "tsup && tsc --emitDeclarationOnly",
    "clean": "rimraf dist schema/*.schema.json"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}