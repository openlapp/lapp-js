{
  "name": "@openlapp/lapp",
  "version": "1.0.0",
  "description": "TypeScript SDK for LAPP (Local AI Provider Profiles): read, validate, write, manage, and send requests to configured providers.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.18.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "USER_AGREEMENT.en.md",
    "USER_AGREEMENT.zh-CN.md",
    "spec.en.md",
    "spec.zh-CN.md",
    "schema",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/openlapp/lapp-js.git",
    "directory": "packages/lapp"
  },
  "keywords": ["lapp", "ai", "llm", "provider", "profile", "sdk", "openai", "anthropic", "claude", "model-registry"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
