{
  "name": "lapp-js",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript SDK and CLI workspace for LAPP (Local AI Provider Profiles).",
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @openlapp/lapp --filter @openlapp/cli run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "verify:docs": "tsx scripts/verify-cli-docs.mts && tsx scripts/verify-protocols.mts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}